#!/usr/bin/env bash
# by Andrey A. Ugolnik
# https://github.com/reybits

path=$1
if [[ "$path" == \** ]]; then
    session=${path:2}

    # session details
    window_count=$(tmux list-windows -t "$session" 2>/dev/null | wc -l | tr -d ' ')
    session_path=$(tmux display-message -t "$session" -p '#{pane_current_path}' 2>/dev/null)
    active_cmd=$(tmux display-message -t "$session" -p '#{pane_current_command}' 2>/dev/null)

    echo -e "\033[1;34m$session\033[0m  \033[33m$window_count windows\033[0m  \033[36m$active_cmd\033[0m"
    echo -e "\033[90m$session_path\033[0m"

    # list windows
    echo ""
    tmux list-windows -t "$session" -F "  #{window_index}: #{window_name}#{?window_active, \033[32m(active)\033[0m,}" 2>/dev/null

    # capture active pane content
    echo ""
    echo -e "\033[90m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\033[0m"
    tmux capture-pane -t "$session" -p -e 2>/dev/null

elif [[ "$path" == \!* ]]; then
    echo -e "\033[31mYou should export env variable SESSION_PATHS.\033[0m"
    echo ""
    echo "Example:"
    echo "   SESSION_PATHS=~/projects:~/docs"
    echo "   export SESSION_PATHS"

elif [[ -n $path ]]; then
    echo -e "\033[36mCreate session at:\033[0m"
    echo ""

    # show git branch if it's a repo
    if git -C "$path" rev-parse --is-inside-work-tree &>/dev/null; then
        branch=$(git -C "$path" branch --show-current 2>/dev/null)
        echo -e "\033[33mGit branch:\033[0m $branch"
        echo ""
    fi

    tree -L 1 -C --dirsfirst "$path"
fi
